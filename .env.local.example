# Supabase — get from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL — no trailing slash
NEXT_PUBLIC_SITE_URL=https://signal.lab

# Attribution — salted IP hashing (never store raw IPs)
# Use a long random string. Rotate via migration + re-hash if compromised.
ATTRIBUTION_SALT=change-me-to-a-long-random-string

# Internal secret — protects /api/admin/log-event from public POST abuse
INTERNAL_LOG_SECRET=change-me-to-another-long-random-string

# Admin protection — basic auth is enforced for /admin and /api/admin/*
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-admin-password

# Soft gate for /project — comma-separated invite tokens
PROJECT_INVITE_TOKENS=
